  </div>
  <div class="filter">
    <div class="icon"><i class="fa-solid fa-umbrella-beach"></i></div>
    <p>Beachfront</p>
  </div>
  <div class="filter">
    <div class="icon"><i class="fa-solid fa-tree"></i></div>
